[Unit]
Description=PingWatch Remote Probe Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# install.sh patches WorkingDirectory/ExecStart to the install location
WorkingDirectory=/opt/pingwatch-agent
ExecStart=/usr/bin/python3 /opt/pingwatch-agent/agent.py
Restart=always
RestartSec=10
User=root

[Install]
WantedBy=multi-user.target
